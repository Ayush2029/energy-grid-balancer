# Energy Grid Balancer — Environment Variables
# Copy to .env and fill in your values.  Never commit .env.

# Required for inference.py
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
HF_TOKEN=sk-your-key-here

# Optional — base URL of the running OpenEnv server
# Defaults to http://localhost:7860 (local) or detected HF Space URL
# ENV_BASE_URL=http://localhost:7860

# Server port (default 7860 for HF Spaces)
# PORT=7860
